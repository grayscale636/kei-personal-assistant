# PostgreSQL Configuration
# Format: postgresql://user:password@host:port/dbname
# Inside Docker, host is the bot network's gateway (e.g. 172.24.0.1) when PG runs on the host machine.
DATABASE_URL=postgresql://keibot:KeiBot2024!@172.24.0.1:5432/bot_kei

